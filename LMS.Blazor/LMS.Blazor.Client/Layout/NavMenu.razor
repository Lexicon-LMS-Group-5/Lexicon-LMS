@inject NavigationManager NavigationManager
@using LMS.Shared

<input type="checkbox" id="nav-toggle" class="nav-toggle" @bind="isNavOpen" />

<div class="sidebar-shell">
    <div class="sidebar-header">
        <a class="navbar-brand" href="">
            <span class="brand-icon">
                <BookIcon />
            </span>
            <span>Lexicon LMS</span>
        </a>

        <label for="nav-toggle" class="navbar-toggler" aria-label="Toggle navigation">
            <span></span>
        </label>
    </div>

    <div class="nav-scrollable">
        <nav class="nav-menu">
            <AuthorizeView Roles=@Roles.Teacher>
                <Authorized>
                    <div class="nav-item">
                        <NavLink class="nav-link" href="?tab=overview" Match="NavLinkMatch.All" @onclick="CloseMenu">
                            <span class="nav-icon"><HouseIcon /></span>
                            <span>Dashboard</span>
                        </NavLink>
                    </div>

                    <div class="nav-item">
                        <NavLink class="nav-link" href="users" Match="NavLinkMatch.Prefix" @onclick="CloseMenu">
                            <span class="nav-icon"><UsersIcon /></span>
                            <span>Users</span>
                        </NavLink>
                    </div>
                </Authorized>
            </AuthorizeView>

            <AuthorizeView>
                <Authorized>
                    <div class="nav-item">
                        <NavLink class="nav-link" href="my-course" Match="NavLinkMatch.All" @onclick="CloseMenu">
                            <span class="nav-icon"><CourseIcon /></span>
                            <span>My Course</span>
                        </NavLink>
                    </div>
                </Authorized>
            </AuthorizeView>
        </nav>

        <AuthorizeView>
            <Authorized>
                <div class="mobile-sidebar-footer">
                    <div class="text-center">
                        <NavLink href="Account/Manage" class="mobile-profile-link" @onclick="CloseMenu">
                            <span class="mobile-profile-icon">
                                <CircleProfile />
                            </span>
                            <span class="mobile-profile-name">@context.User.Identity?.Name</span>
                        </NavLink>
                    </div>

                    <form action="Account/Logout" method="post" class="mobile-logout-form">
                        <AntiforgeryToken />
                        <input type="hidden" name="ReturnUrl" value="@BuildReturnUrl()" />
                        <button type="submit" class="mobile-logout-button" @onclick="CloseMenu">
                            <LogoutIcon />
                            <span>Logout</span>
                        </button>
                    </form>
                </div>
            </Authorized>
        </AuthorizeView>
    </div>
</div>

@code {
    private bool isNavOpen;

    private void CloseMenu()
    {
        isNavOpen = false;
    }

    private string BuildReturnUrl()
    {
        var relative = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        return string.IsNullOrWhiteSpace(relative) ? "/" : relative;
    }
}