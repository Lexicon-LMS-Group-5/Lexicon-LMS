@inherits LayoutComponentBase
@implements IDisposable

@inject NavigationManager NavigationManager

<div class="page">
    <AuthorizeView>
        <NotAuthorized>
            <main class="main-area full-width">
                <article class="content-area">
                    @Body
                </article>
            </main>
        </NotAuthorized>
    </AuthorizeView>

    <AuthorizeView>
        <Authorized>
            <aside class="sidebar">
                <NavMenu />
            </aside>

            <main class="main-area">
                <header class="app-header">
                    <div class="header-profile">
                        <NavLink href="Account/Manage" class="profile-link profile-icon-link">
                            <span class="profile-icon">
                                <CircleProfile />
                            </span>
                        </NavLink>

                        <NavLink href="Account/Manage" class="profile-link profile-name">
                            @context.User.Identity?.Name
                        </NavLink>
                    </div>

                    <div class="header-actions">
                        <form action="Account/Logout" method="post" class="logout-form">
                            <AntiforgeryToken />
                            <input type="hidden" name="ReturnUrl" value="@currentUrl" />
                            <button type="submit" class="logout-button">
                                <LogoutIcon />
                                <span>Logout</span>
                            </button>
                        </form>
                    </div>
                </header>

                <article class="content-area">
                    @Body
                </article>
            </main>
        </Authorized>
    </AuthorizeView>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private string? currentUrl;

    protected override void OnInitialized()
    {
        currentUrl = BuildReturnUrl(NavigationManager.Uri);
        NavigationManager.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        currentUrl = BuildReturnUrl(e.Location);
        InvokeAsync(StateHasChanged);
    }

    private string BuildReturnUrl(string absoluteUri)
    {
        var relative = NavigationManager.ToBaseRelativePath(absoluteUri);
        return string.IsNullOrWhiteSpace(relative) ? "/" : relative;
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
    }
}
