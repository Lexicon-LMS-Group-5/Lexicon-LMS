<Tab Title="Modules">
    <ErrorBoundary @ref="ModulesTabErrorBoundary">
        <ChildContent>
            <div class="d-flex flex-column gap-3 p-3">
                <header>
                    <h2 class="fs-5">Modules</h2>
                </header>
                <div class="modules-list rounded-3 overflow-hidden shadow-sm">
                    @foreach (var module in Modules)
                    {
                        <button class="module-list-item accordion-button d-flex gap-3 p-3 w-100 text-start"
                                @onclick="() => selectedModuleId = selectedModuleId == module.Id ? null : module.Id"
                                data-bs-toggle="collapse" 
                                data-bs-target="@($"#module-item-{module.Id}")"
                                aria-expanded="false" 
                                aria-controls="@($"module-item-{module.Id}")">
                            <div class="d-flex my-auto rounded-circle bg-primary-subtle text-primary p-2">
                                <LayersIcon />
                            </div>
                            <div class="d-flex flex-column gap-1 flex-grow-1">
                                <div>
                                    @module.Name test
                                </div>
                                <div class="text-secondary">
                                    @module.StartDate.ToShortDateString() - @module.EndDate.ToShortDateString()
                                </div>
                            </div>
                            <div class="my-auto">
                                <div class="text-secondary" style="@(module.Id == selectedModuleId ? openedChevronIconStyles : closedChevronIconStyles)")>
                                    <ChevronUpIcon />
                                </div>
                            </div>
                        </button>
                        <div class="@($"collapse {(module.Id == selectedModuleId ? "show" : "")}")" id="@($"module-item-{module.Id}")">
                            <div class="p-4 d-flex flex-column gap-3">
                                <div>
                                    @module.Description
                                </div>
                                <div>
                                    <h3 class="fs-6 fw-bold">Activities</h3>
                                </div>
                                <div class="d-flex flex-column gap-2">
                                    @foreach (var activity in module.Activities)
                                    {
                                        <div class="p-3 bg-body rounded border">
                                            <div class="d-flex flex-column gap-2">
                                                <div class="d-flex flex-column gap-1">
                                                    <div class="d-flex gap-2">
                                                        <div class="badge bg-primary-subtle text-primary rounded-pill my-auto">
                                                            @activity.ActivityTypeName
                                                        </div>
                                                        <div>
                                                            @activity.Name
                                                        </div>
                                                    </div>
                                                    <div class="text-secondary fw-bold d-flex gap-2" style="font-size: .75em">
                                                        <CalendarIcon Size="16" /> 
                                                        <div>@activity.EndDate.ToShortDateString()</div>
                                                    </div>
                                                </div>
                                                <div class="border-bottom"></div>
                                                <div>
                                                    <div class="text-secondary fw-bold d-flex gap-2" style="font-size: .75em">
                                                        Documents
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </ChildContent>
        <ErrorContent>
            <div class="d-flex w-100 h-100 flex-column justify-content-center align-items-middle">
                <div class="flex flex-column text-center justify-content-center align-items-middle gap-5">
                    <h3 class="p-5">Something went wrong...</h3>

                    @if (ErrorMessage != null)
                    {
                        <p>@ErrorMessage</p>
                    }
              
                    <button class="btn btn-primary" @onclick="() => ModulesTabErrorBoundary?.Recover()">Try to reload</button>
                </div>
            </div>
        </ErrorContent>
    </ErrorBoundary>
</Tab>

@code {
    [Inject]
    private IApiService ApiService { get; set; } = default!;

    [Parameter]
    public RenderFragment? ChildContent { get; set; } = default!;

    [Parameter]
    public int CourseId { get; set; }

    [Parameter]
    public CourseDetailsDto CourseDetails { get; set; }

    private bool IsLoading { get; set; }
    private IReadOnlyList<ModuleReadDto> Modules { get; set; } = [];
    private string? ErrorMessage { get; set; }
    private ErrorBoundaryBase? ModulesTabErrorBoundary { get; set; }

    private int? selectedModuleId = null;
    private string closedChevronIconStyles = "transform: rotate(90deg);";
    private string openedChevronIconStyles = "transform: rotate(180deg);";

    protected override async Task OnInitializedAsync()
    {
        selectedModuleId = CourseDetails?.Modules.FirstOrDefault()?.Id ?? null;

        IsLoading = true;

        try
        {
            Modules = await ApiService.GetAsync<IReadOnlyList<ModuleReadDto>>($"api/modules/{CourseId}")
                ?? throw new Exception("Could not fetch modules");
        } catch(Exception ex)
        {
            ErrorMessage = ex.Message;
        } finally
        {
            IsLoading = false;
        }
    }
}
