@page "/dashboard/courses/{courseId}"

<PageTitle>@(IsLoading ? "Loading course details..." : CourseDetails?.Name ?? "Course Details")</PageTitle>

@if (Referrer == "dashboard")
{
    <div class="mb-3">
    <NavLink 
        class="icon-link text-primary link-underline-primary link-underline-opacity-0 link-underline-opacity-75-hover" 
        href="@($"/dashboard?tab={ReferrerTab ?? "overview"}")">
        <span style="transform: rotate(-90deg);">
            <ChevronUpIcon />
        </span>
        Back to Dashboard
    </NavLink>
    </div>
}

<div class="d-flex flex-column gap-5 pb-5">
    <CourseDetailsHeader CourseDetails="CourseDetails" IsLoading="IsLoading" OnOpenModal="() => ShowModalAsync(EditCourseModalId)">
        <CourseDetailsHeaderActions>
            <AuthorizeView Roles="Teacher">
                <button class="btn btn-primary my-auto d-flex gap-2"
                        type="button"
                        disabled="@(CourseDetails == null)"
                        @onclick="() => ShowModalAsync(EditCourseModalId)">
                    <div class="my-auto d-flex flex-column justify-content-center">
                        <PencilIcon Size="16" />
                    </div>
                    <div class="">
                        Edit course
                    </div>
                </button>
                <button 
                    class="btn btn-outline-danger my-auto"
                    disabled="@(CourseDetails == null)"
                        @onclick="() => ShowModalAsync(DeleteCourseConfirmationModalId)">
                    <TrashIcon />
                </button>
            </AuthorizeView>
        </CourseDetailsHeaderActions>
    </CourseDetailsHeader>


    <TabContainer 
        CurrentRoute="@($"/dashboard/courses/{CourseId}")" 
        TabTitles="@(["Course Overview", "Modules", "Students"])">
        <Tab Title="Course Overview">
            <div class="container p-0">
                <div class="row row-cols-1 row-cols-lg-2 g-3">
                    <div class="col">
                        <div class="d-flex flex-column p-4 bg-body gap-4 rounded">
                            <div>
                                <h2 class="fs-5">Course progress</h2>
                                <div>
                                    <div class="d-flex gap-2 align-items-middle">
                                        <div class="text-primary fs-4 fw-bold">35%</div>
                                        <div class="text-secondary d-flex flex-column justify-content-center">completed on average</div>
                                    </div>
                                    <div>
                                        <div class="progress" role="progressbar" aria-label="Basic example" aria-valuenow="75" aria-valuemin="0" aria-valuemax="100">
                                            <div class="progress-bar" style="width: 35%"></div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="d-flex flex-column gap-3">
                                <h3 class="fs-6 fw-bold">Modules</h3>
                                @if (IsLoading || CourseDetails == null)
                                {
                                    <div class="d-flex gap-3 align-items-middle w-100">
                                        <div class="w-100 placeholder-glow">
                                            <span class="rounded placeholder col-6"></span>
                                        </div>
                                        <div class="w-100 d-flex flex-column justify-content-center">
                                            <div class="progress" role="progressbar" aria-label="Example 20px high" aria-valuenow="25" aria-valuemin="0" aria-valuemax="100" style="height: 8px">
                                                <div class="progress-bar progress-bar-striped progress-bar-animated bg-secondary-subtle" style="width: 100%"></div>
                                            </div>
                                        </div>
                                        <div class="fs-6 text-secondary fw-bold d-flex flex-column justify-content-center placeholder-glow">
                                            <div class="rounded placeholder col-3"></div>
                                        </div>
                                    </div>
                                } else
                                {
                                    @foreach (var module in CourseDetails.Modules)
                                    {
                                        <div class="d-flex gap-3 align-items-middle w-100">
                                            <div class="w-100">@module.Name</div>
                                            <div class="w-100 d-flex flex-column justify-content-center">
                                                <div class="progress" role="progressbar" aria-label="Example 20px high" aria-valuenow="25" aria-valuemin="0" aria-valuemax="100" style="height: 8px">
                                                    <div class="progress-bar" style="width: 25%"></div>
                                                </div>
                                            </div>
                                            <div class="fs-6 text-secondary fw-bold d-flex flex-column justify-content-center">
                                                24%
                                            </div>
                                        </div>
                                    }
                                }
                            </div>
                        </div>
                    </div>
                    <div class="co">
                        <div class="d-flex flex-column p-3  bg-body rounded h-100">
                            <h2 class="fs-5">Course stats</h2>
                        </div>
                    </div>
                </div>
            </div>
        </Tab>
        <Tab Title="Modules">
            @if (CourseDetails != null)
            {
                <ModulesTab CourseId="CourseDetails.Id" CourseDetails="CourseDetails" />
            }
        </Tab>
        <Tab Title="Students">
            @if (CourseDetails != null) {
                <StudentsTab CourseId="CourseDetails.Id" Students="@(CourseDetails.Participants.Where(s => s.Role == "Student").ToList())" />
            }
        </Tab>
    </TabContainer>
</div>

<Modal ModalId="@DeleteCourseConfirmationModalId">
    <ModalHeader
        ModalId="@DeleteCourseConfirmationModalId"
        Title="Are you sure?" />
    <ModalBody>
        <div class="d-flex w-100 h-100 justify-content-center align-items-middle">
            <div>
                This will permanently delete this course and all of its content.
            </div>
        </div>
    </ModalBody>
    <ModalFooter>
        <button
            class="btn btn-outline-secondary"
            @onclick="() => HideModalAsync(DeleteCourseConfirmationModalId)">
            Cancel
        </button>
        <button
            class="btn btn-danger"
            @onclick="ConfirmDeleteThisAsync">
            Delete
        </button>
    </ModalFooter>
</Modal>

@if (CourseDetails != null && EditContext != null)
{
    <Modal ModalId="@EditCourseModalId">
        <ModalHeader 
            ModalId="@EditCourseModalId" 
            Title="Edit Course" />
        <EditCourseForm 
            EditContext="EditContext" 
            CourseDetails="CourseDetails" 
            Model="EditCourseModel"
            OnSubmissionRequested="OnEditCourseSubmissionRequested"
            OnSubmissionFailed="OnEditCourseSubmissionFailed"
            OnSubmissionCanceled="OnEditCourseSubmissionCanceledAsync"
            OnSubmissionSucceeded="OnEditCourseSubmissionSucceededAsync">
            <FormContent>
                <ModalBody>
                    <EditCourseFormContent 
                        CourseDetails="CourseDetails" 
                        Model="EditCourseModel" />
                </ModalBody>
            </FormContent>
            <FormActions>
                <ModalFooter>
                    <button 
                        class="btn btn-secondary"
                        type="button" 
                        @onclick="OnEditCourseSubmissionCanceledAsync">
                        Cancel
                    </button>
                    <button 
                        class="btn btn-primary"
                        type="submit"
                        disabled="@IsFormLoading">
                        Save changes
                    </button>
                </ModalFooter>
            </FormActions>
        </EditCourseForm>
    </Modal>
}
