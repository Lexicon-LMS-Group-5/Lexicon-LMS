@page "/module/{ModuleId:int}"
@using LMS.Blazor.Client.Components
@using LMS.Shared.DTOs
@inject IApiService ApiService
@inject NavigationManager NavigationManager

@if (Module == null)
{
    <p>Loading module...</p>
}
else
{
    <h2>Module Details</h2>

    <div>
        <h3>@Module.Name</h3>
        <p>@Module.Description</p>
        <small>
            Start: @Module.StartDate.ToShortDateString() <br />
            End: @Module.EndDate.ToShortDateString()
        </small>
    </div>

    <h4>Activities</h4>
    @if (Activities != null && Activities.Any())
    {
        @foreach (var activity in Activities)
        {
            <ActivityComponent Activity="activity" ModuleId="@Module.Id" CourseId="@CourseId" />
        }
    }
    else
    {
        <p>No activities found for this module.</p>
    }

}



@code {
    [Parameter]
    public int ModuleId { get; set; }

    [Parameter]
    public int CourseId { get; set; }

    private ModuleReadDto Module { get; set; }
    private List<ActivityReadDto> Activities { get; set; } = new();

    protected override async Task OnInitializedAsync()
    {
        // Fetch module details
        Module = await ApiService.GetAsync<ModuleReadDto>($"api/modules/{ModuleId}");

        // Fetch activities for this module
        Activities = await ApiService.GetAsync<List<ActivityReadDto>>($"api/modules/{ModuleId}/activities");
    }
}