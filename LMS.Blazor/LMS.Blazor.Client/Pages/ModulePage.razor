@page "/module/{CourseId:int}/{ModuleId:int}"
@using LMS.Blazor.Client.Components
@using LMS.Shared.DTOs
@using LMS.Shared
@inject IJSRuntime JS
@inject IApiService ApiService
@inject NavigationManager NavigationManager

@if (Module == null)
{
        <div class="d-flex justify-content-center mt-5">
        <div class="spinner-border text-primary"></div>
    </div>
}
else
{
    @if (ShowSuccessMessage)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            Activity created successfully!
            <button type="button" class="btn-close" @onclick="() => ShowSuccessMessage = false"></button>
        </div>
    }

    <Breadcrumbs CourseId="@CourseId"
                 ModuleId="@Module.Id"
                 CourseName="@Module.CourseName"
                 ModuleName="@Module.Name" />

    <div class="container py-4">
        <div class="mb-4">
            
            <AuthorizeView Roles=@Roles.Teacher>
                <button class="btn btn-outline-secondary btn-sm mb-3"
                        @onclick="DeleteThis">
                    Delete this module
                </button>
            </AuthorizeView>
            <h1 class="fw-bold">@Module.Name</h1>
            <p class="text-muted mb-0">@Module.CourseName</p>
        </div>

        <div class="card shadow-sm border-0 mb-4">
            <div class="card-body">
                <h5 class="card-title">Description</h5>
                <p class="card-text">@Module.Description</p>
            </div>
        </div>

        <div class="card shadow-sm border-0 mb-4">
            <div class="card-body">
                <h5 class="card-title">Schedule</h5>
                <p class="mb-1">
                    <strong>Start:</strong> @Module.StartDate.ToShortDateString()
                </p>
                <p class="mb-0">
                    <strong>End:</strong> @Module.EndDate.ToShortDateString()
                </p>
            </div>
        </div>

        <div class="mb-3">
            <h3 class="fw-semibold">Activities</h3>
        </div>

        <AuthorizeView Roles=@Roles.Teacher>
            <div data-bs-toggle="modal"
                 data-bs-target="#createActivityModal">
                <button class="btn btn-primary btn-sm mb-3">
                    + Add Activity
                </button>
            </div>
        </AuthorizeView>

        @if (Module.Activities != null && Module.Activities.Any())
        {
            <div class="row">
                @foreach (var activity in Module.Activities)
                {
                    <div class="col-md-6 col-lg-4">
                        <ActivityComponent Activity="activity"
                                           ModuleId="@Module.Id"
                                           CourseId="@CourseId" />
                    </div>
                }
            </div>
        }
        else
        {
            <div class="alert alert-secondary">
                No activities found for this module.
            </div>
        }

    </div>

    <AuthorizeView Roles=@Roles.Teacher>
        <div class="modal fade" id="createActivityModal" tabindex="-1">
            <div class="modal-dialog">
                <div class="modal-content">

                    <div class="modal-header">
                        <h5 class="modal-title">Create Activity</h5>
                        <button class="btn-close" data-bs-dismiss="modal"></button>
                    </div>

                    <div class="modal-body">
                        <CreateActivityForm CourseId="@CourseId"
                                            ModuleId="@Module.Id"
                                            OnCreated="HandleActivityCreated">

                            <ModalCloseButton>
                                <button class="btn btn-secondary"
                                        data-bs-dismiss="modal">
                                    Close
                                </button>
                            </ModalCloseButton>

                        </CreateActivityForm>
                    </div>

                </div>
            </div>
        </div>
    </AuthorizeView>
}


@code {

        private bool ShowSuccessMessage = false;

        [Parameter]
        public int ModuleId { get; set; }

        [Parameter]
        public int CourseId { get; set; }
    public string Url {get { return $"api/modules/{CourseId}/{ModuleId}"; }}

    private ModuleReadDto Module { get; set; } = new();
    private List<ActivityReadDto> Activities { get; set; } = new();

    private async Task HandleActivityCreated()
    {
        await JS.InvokeVoidAsync("closeBootstrapModal", "#createActivityModal");

        ShowSuccessMessage = true;

        await LoadModule();
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadModule();
    }

    private async Task LoadModule()
    {
        var m = await ApiService.GetAsync<ModuleReadDto>(Url);
        Module = m ?? new();
    }

    private void GoBack()
    {
        NavigationManager.NavigateTo("/my-course");
    }
    private async Task DeleteThis()
    {
        await ApiService.DeleteAsync(Url);
        GoBack();
    }
}
