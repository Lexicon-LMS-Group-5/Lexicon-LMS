@page "/module/{CourseId:int}/{ModuleId:int}"
@using LMS.Blazor.Client.Components
@using LMS.Shared.DTOs
@inject IApiService ApiService
@inject NavigationManager NavigationManager

@if (Module == null)
{
    <div class="d-flex justify-content-center mt-5">
        <div class="spinner-border text-primary"></div>
    </div>
}
else
{
    <div class="container py-4">
        <div class="mb-4">
            <button class="btn btn-outline-secondary btn-sm mb-3"
                    @onclick="GoBack">
                ← Back to course
            </button>
            <button class="btn btn-outline-secondary btn-sm mb-3"
                    @onclick="DeleteThis">
                Delete this module
            </button>
            <h1 class="fw-bold">@Module.Name</h1>
            <p class="text-muted mb-0">@Module.CourseName</p>
        </div>

        <div class="card shadow-sm border-0 mb-4">
            <div class="card-body">
                <h5 class="card-title">Description</h5>
                <p class="card-text">@Module.Description</p>
            </div>
        </div>

        <div class="card shadow-sm border-0 mb-4">
            <div class="card-body">
                <h5 class="card-title">Schedule</h5>
                <p class="mb-1">
                    <strong>Start:</strong> @Module.StartDate.ToShortDateString()
                </p>
                <p class="mb-0">
                    <strong>End:</strong> @Module.EndDate.ToShortDateString()
                </p>
            </div>
        </div>

        <div class="mb-3">
            <h3 class="fw-semibold">Activities</h3>
        </div>

        @if (Module.Activities != null && Module.Activities.Any())
        {
            <div class="row">
                @foreach (var activity in Module.Activities)
                {
                    <div class="col-md-6 col-lg-4">
                        <ActivityComponent Activity="activity"
                                           ModuleId="@Module.Id"
                                           CourseId="@CourseId" />
                    </div>
                }
            </div>
        }
        else
        {
            <div class="alert alert-secondary">
                No activities found for this module.
            </div>
        }

    </div>
}


@code {
        [Parameter]
        public int ModuleId { get; set; }

        [Parameter]
        public int CourseId { get; set; }
    public string Url {get { return $"api/modules/{CourseId}/{ModuleId}"; }}

    private ModuleReadDto Module { get; set; } = new();
    private List<ActivityReadDto> Activities { get; set; } = new();


    protected override async Task OnInitializedAsync()
    {
        var m = await ApiService.GetAsync<ModuleReadDto>(Url);
        Module = m ?? new();
    }

    private void GoBack()
    {
        NavigationManager.NavigateTo($"/my-course");
    }
    private async Task DeleteThis()
    {
        await ApiService.DeleteAsync(Url);
    }
}