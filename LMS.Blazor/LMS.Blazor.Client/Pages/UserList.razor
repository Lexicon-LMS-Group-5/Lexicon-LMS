@page "/users"
@using LMS.Blazor.Client.Components.UserModals
@using LMS.Shared
@using LMS.Shared.DTOs
@attribute [Authorize(Roles = Roles.Teacher)]

<PageTitle>User List</PageTitle>
<h3 class="mb-4">Users</h3>
<div class="d-flex gap-2">
    <QuickActionButton OnClick="OpenCreateModal">
        <ButtonIcon>
            <CirclePlusIcon />
        </ButtonIcon>
        <ButtonText>
            Add a new Teacher
        </ButtonText>
    </QuickActionButton>
</div>
<input class="form-control mb-3"
       placeholder="Search users..."
       @bind="SearchTerm"
       @bind:event="onchange" />
@if (IsLoading)
{
    <div class="text-center mt-4">
        <div class="spinner-border" role="status"></div>
    </div>
}
else if (_allUsers == null || !_allUsers.Any())
{
    <div class="alert alert-info">
        No users found.
    </div>
}
else if (_filteredUsers == null || !_filteredUsers.Any())
{
    <div class="alert alert-info">
        No users match your search.
    </div>
}
else
{
    <table class="table table-striped table-hover">
        <thead class="table-light">
            <tr>
                <th scope="col" @onclick='() => SortBy("Name")' style="cursor:pointer">
                    Name
                    @(_sortColumn == "Name" ? (_sortAscending? " ▲" : " ▼") : "")
                </th>
                <th scope="col" @onclick='() => SortBy("Email")' style="cursor:pointer">
                    Email
                    @(_sortColumn == "Email" ? (_sortAscending? " ▲" : " ▼") : "")
                </th>
                <th scope="col" @onclick='() => SortBy("Course")' style="cursor:pointer">
                    Course
                    @(_sortColumn == "Course" ? (_sortAscending ? " ▲" : " ▼") : "")
                </th>
                <th scope="col"@onclick='() => SortBy("Roles")' style="cursor:pointer">
                    Roles
                    @(_sortColumn == "Roles" ? (_sortAscending? " ▲" : " ▼") : "")
                </th>
                <th>
                    Actions
                </th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in _pagedUsers ?? Enumerable.Empty<UserReadDto>())
            {
                <tr>
                    <td>@user.FullName</td>
                    <td>@user.Email</td>
                    <td>@(user.CourseName ?? "No Course")</td>
                    <td>
                        @if (user.Roles != null && user.Roles.Any())
                        {
                            @foreach (var role in user.Roles)
                            {
                                @if (role == Roles.Teacher)
                                {
                                    <span class="badge bg-info me-1">@role</span>
                                }
                                else
                                {
                                    <span class="badge bg-primary me-1">@role</span>
                                }
                            }
                        }
                        else
                        {
                            <span class="text-muted">No roles</span>
                        }
                    </td>
                    <td>
                        <button class="btn btn-sm btn-warning"
                                @onclick="() => OpenEditModal(user.Id)">
                            Edit
                        </button>
                        <button class="btn btn-sm btn-danger"
                                disabled="@IsCurrentUser(user.Id)"
                                @onclick="() => OpenDeleteModal(user.Id, user.FullName)">
                            Delete
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
    @if (TotalPages > 1)
    {
    <nav aria-label="User list pagination">
        <ul class="pagination justify-content-center">
            <li class="page-item @(_currentPage == 1 ? "disabled" : "")">
                <button class="page-link" @onclick="PreviousPage" aria-label="Previous">
                    <span aria-hidden="true">&laquo;</span>
                </button>
            </li>

            @for (int i = 1; i <= TotalPages; i++)
            {
                var page = i; 
                <li class="page-item @(_currentPage == i ? "active" : "")">
                    <button class="page-link" @onclick="() => GoToPage(page)">@i</button>
                </li>
            }

            <li class="page-item @(_currentPage == TotalPages ? "disabled" : "")">
                <button class="page-link" @onclick="NextPage" aria-label="Next">
                    <span aria-hidden="true">&raquo;</span>
                </button>
            </li>
        </ul>
    </nav>
    }
    <div class="text-center mt-2">
        Showing @((_currentPage - 1) * _pageSize + 1)
        -
        @(Math.Min(_currentPage * _pageSize, _filteredUsers?.Count ?? 0))
        of @(_filteredUsers?.Count ?? 0) users
    </div>

    @if (_activeModal != ModalType.None)
    {
        <div class="modal fade @( _isModalVisible ? "show" : "" ) d-block" tabindex="-1"
             @onclick="CloseModal">
            <div class="modal-dialog" @onclick:stopPropagation="true">
                <div class="modal-content">
                    @switch (_activeModal)
                    {
                        case ModalType.EditUser:
                            <div class="modal-header">
                                <h5>Edit User</h5>
                                <button class="btn-close" @onclick="CloseModal"></button>
                            </div>
                            <div class="modal-body">
                                <EditUserForm @key="_selectedUserId"
                                              Id="@_selectedUserId"
                                              OnSaved="HandleUserSaved"
                                              OnCancel="CloseModal" />
                            </div>
                            break;

                        case ModalType.CreateUser:
                            <div class="modal-header">
                                <h5>Add Teacher</h5>
                                <button class="btn-close" @onclick="CloseModal"></button>
                            </div>
                            <div class="modal-body">
                                <CreateUserForm OnSaved="HandleUserSaved"
                                                OnCancel="CloseModal" />
                            </div>
                            break;

                        case ModalType.CreateStudent:
                            <div class="modal-header">
                                <h5>Add Student</h5>
                                <button class="btn-close" @onclick="CloseModal"></button>
                            </div>
                            <div class="modal-body">
                                <CreateStudentForm @key="_courseIdTemp"
                                                   CourseId="@_courseIdTemp"
                                                   OnSaved="HandleUserSaved"
                                                   OnCancel="CloseModal" />
                            </div>
                            break;

                        case ModalType.DeleteUser:
                            <div class="modal-header">
                                <h5>Confirmation</h5>
                                <button class="btn-close" @onclick="CloseModal"></button>
                            </div>
                            <div class="modal-body">
                                <DeleteUserConfirmation @key="_selectedUserId"
                                                        UserId="@_selectedUserId"
                                                        UserName="@_selectedUserName"
                                                        OnDeleted="HandleUserSaved"
                                                        OnCancel="CloseModal" />
                            </div>
                            break;
                    }
                </div>
            </div>
        </div>
        <div class="modal-backdrop fade @( _isModalVisible ? "show" : "" )">
        </div>
    }
}