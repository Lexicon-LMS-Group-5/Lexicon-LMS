@page "/users"

@using LMS.Shared.DTOs
@attribute [Authorize(Roles = "Teacher")]

<h3 class="mb-4">Users</h3>
<button class="btn btn-sm btn-success"
        @onclick="OpenCreateModal">
    Create User
</button>
<input class="form-control mb-3"
       placeholder="Search users..."
       @bind="SearchTerm"
       @bind:event="oninput" />
@if (IsLoading)
{
    <div class="text-center mt-4">
        <div class="spinner-border" role="status"></div>
    </div>
}
else if (Users == null || !Users.Any())
{
    <div class="alert alert-info">
        No users found.
    </div>
}
else
{
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th @onclick='() => SortBy("Name")' style="cursor:pointer">
                    Name
                    @(_sortColumn == "Name" ? (_sortAscending? " ▲" : " ▼") : "")
                </th>
                <th @onclick='() => SortBy("Email")' style="cursor:pointer">
                    Email
                    @(_sortColumn == "Email" ? (_sortAscending? " ▲" : " ▼") : "")
                </th>
                <th @onclick='() => SortBy("Course")' style="cursor:pointer">
                    Course
                    @(_sortColumn == "Course" ? (_sortAscending ? " ▲" : " ▼") : "")
                </th>
                <th @onclick='() => SortBy("Roles")' style="cursor:pointer">
                    Roles
                    @(_sortColumn == "Roles" ? (_sortAscending? " ▲" : " ▼") : "")
                </th>
                <th>
                    Actions
                </th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Users)
            {
                <tr>
                    <td>@user.FullName</td>
                    <td>@user.Email</td>
                    <td>@(user.Course?.Name ?? "No Course")</td>
                    <td>
                        @if (user.Roles != null && user.Roles.Any())
                        {
                            @foreach (var role in user.Roles)
                            {
                                @if (role == "Teacher")
                                {
                                    <span class="badge bg-info me-1">@role</span>
                                }
                                else
                                {
                                    <span class="badge bg-primary me-1">@role</span>
                                }
                            }
                        }
                        else
                        {
                            <span class="text-muted">No roles</span>
                        }
                    </td>
                    <td>
                        <button class="btn btn-sm btn-warning"
                                @onclick="() => OpenEditModal(user.Id)">
                            Edit
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
    @if (ActiveModal == ModalType.EditUser)
    {
        <div class="modal fade show d-block" tabindex="-1">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5>Edit User</h5>
                        <button class="btn-close" @onclick="CloseModal"></button>
                    </div>
                    <div class="modal-body">
                        <EditUserForm @key="SelectedUserId"
                                      Id="@SelectedUserId"
                                      OnSaved="HandleUserSaved"
                                      OnCancel="CloseModal" />
                    </div>
                </div>
            </div>
        </div>

        <div class="modal-backdrop fade show"></div>
    }

    @if (ActiveModal == ModalType.CreateUser)
    {
        <div class="modal fade show d-block" tabindex="-1">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5>Create User</h5>
                        <button class="btn-close" @onclick="CloseModal"></button>
                    </div>
                    <div class="modal-body">
                        <CreateUserForm OnSaved="HandleUserSaved"
                                        OnCancel="CloseModal" />
                    </div>
                </div>
            </div>
        </div>

        <div class="modal-backdrop fade show"></div>
    }
}