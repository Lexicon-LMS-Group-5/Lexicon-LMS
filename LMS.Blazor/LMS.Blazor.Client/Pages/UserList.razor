@page "/users"

@using LMS.Shared.DTOs
@attribute [Authorize(Roles = "Teacher")]

<div class="d-flex gap-2">
    <QuickActionButton OnClick="OpenCreateModal">
        <ButtonIcon>
            <CirclePlusIcon />
        </ButtonIcon>
        <ButtonText>
            Add a new Teacher
        </ButtonText>
    </QuickActionButton>
</div>

<h3 class="mb-4">Users</h3>
<button class="btn btn-sm btn-success"
        @onclick="OpenCreateModal">
    Add Teacher
</button>
<button class="btn btn-sm btn-success"
        @onclick="OpenTempModal">
    Add Student (Temp)
</button>
<input class="form-control mb-3"
       placeholder="Search users..."
       @bind="SearchTerm"
       @bind:event="oninput" />
@if (IsLoading)
{
    <div class="text-center mt-4">
        <div class="spinner-border" role="status"></div>
    </div>
}
else if (AllUsers == null || !AllUsers.Any())
{
    <div class="alert alert-info">
        No users found.
    </div>
}
else
{
    <table class="table table-striped table-hover">
        <thead class="table-light">
            <tr>
                <th @onclick='() => SortBy("Name")' style="cursor:pointer">
                    Name
                    @(_sortColumn == "Name" ? (_sortAscending? " ▲" : " ▼") : "")
                </th>
                <th @onclick='() => SortBy("Email")' style="cursor:pointer">
                    Email
                    @(_sortColumn == "Email" ? (_sortAscending? " ▲" : " ▼") : "")
                </th>
                <th @onclick='() => SortBy("Course")' style="cursor:pointer">
                    Course
                    @(_sortColumn == "Course" ? (_sortAscending ? " ▲" : " ▼") : "")
                </th>
                <th @onclick='() => SortBy("Roles")' style="cursor:pointer">
                    Roles
                    @(_sortColumn == "Roles" ? (_sortAscending? " ▲" : " ▼") : "")
                </th>
                <th>
                    Actions
                </th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in PagedUsers)
            {
                <tr>
                    <td>@user.FullName</td>
                    <td>@user.Email</td>
                    <td>@(user.Course?.Name ?? "No Course")</td>
                    <td>
                        @if (user.Roles != null && user.Roles.Any())
                        {
                            @foreach (var role in user.Roles)
                            {
                                @if (role == "Teacher")
                                {
                                    <span class="badge bg-info me-1">@role</span>
                                }
                                else
                                {
                                    <span class="badge bg-primary me-1">@role</span>
                                }
                            }
                        }
                        else
                        {
                            <span class="text-muted">No roles</span>
                        }
                    </td>
                    <td>
                        <button class="btn btn-sm btn-warning"
                                @onclick="() => OpenEditModal(user.Id)">
                            Edit
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <nav aria-label="User list pagination">
        <ul class="pagination justify-content-center">
            <li class="page-item @(CurrentPage == 1 ? "disabled" : "")">
                <button class="page-link" @onclick="PreviousPage" aria-label="Previous">
                    <span aria-hidden="true">&laquo;</span>
                </button>
            </li>

            @for (int i = 1; i <= TotalPages; i++)
            {
                var page = i; 
                <li class="page-item @(CurrentPage == i ? "active" : "")">
                    <button class="page-link" @onclick="() => GoToPage(page)">@i</button>
                </li>
            }

            <li class="page-item @(CurrentPage == TotalPages ? "disabled" : "")">
                <button class="page-link" @onclick="NextPage" aria-label="Next">
                    <span aria-hidden="true">&raquo;</span>
                </button>
            </li>
        </ul>
    </nav>

    @if (ActiveModal == ModalType.EditUser)
    {
        <div class="modal fade show d-block" tabindex="-1">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5>Edit User</h5>
                        <button class="btn-close" @onclick="CloseModal"></button>
                    </div>
                    <div class="modal-body">
                        <EditUserForm @key="SelectedUserId"
                                      Id="@SelectedUserId"
                                      OnSaved="HandleUserSaved"
                                      OnCancel="CloseModal" />
                    </div>
                </div>
            </div>
        </div>

        <div class="modal-backdrop fade show"></div>
    }

    @if (ActiveModal == ModalType.CreateUser)
    {
        <div class="modal fade show d-block" tabindex="-1">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5>Create User</h5>
                        <button class="btn-close" @onclick="CloseModal"></button>
                    </div>
                    <div class="modal-body">
                        <CreateUserForm OnSaved="HandleUserSaved"
                                        OnCancel="CloseModal" />
                    </div>
                </div>
            </div>
        </div>

        <div class="modal-backdrop fade show"></div>
    }

    @if (ActiveModal == ModalType.CreateStudent)
    {
        <div class="modal fade show d-block" tabindex="-1">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5>Create User</h5>
                        <button class="btn-close" @onclick="CloseModal"></button>
                    </div>
                    <div class="modal-body">
                        <CreateStudentForm @key="CourseId"
                                        CourseId="@CourseId"    
                                        OnSaved="HandleUserSaved"
                                        OnCancel="CloseModal" />
                    </div>
                </div>
            </div>
        </div>

        <div class="modal-backdrop fade show"></div>
    }
}