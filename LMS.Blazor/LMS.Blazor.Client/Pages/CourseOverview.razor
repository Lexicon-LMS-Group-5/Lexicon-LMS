@page "/my-course"

@using Microsoft.AspNetCore.Authorization

@attribute [Authorize]

<PageTitle>@(CourseDetails?.Name ?? "Loading course details...")</PageTitle>
<h1>@(CourseDetails?.Name ?? "Loading...")</h1>

<AuthorizeView Roles="Teacher">
    <div>Teacher content</div>
</AuthorizeView>

<AuthorizeView Roles="Student">
    <div>Student content</div>
</AuthorizeView>

<div>General content</div>

@if (CourseDetails is null)
{
    <div>Loading...</div>
} else
{
    <div>@CourseDetails.Name</div>
}