@page "/my-course"

@using Microsoft.AspNetCore.Authorization
@using LMS.Shared.DTOs
@using LMS.Blazor.Client.Components

@attribute [Authorize]

<PageTitle>@(CourseDetails?.Name ?? "Loading course details...")</PageTitle>

@if (IsLoading)
{
    <div class="placeholder-glow">Loading...</div>
}
else
{
    if (CourseDetails != null)
    {
        <div class="container py-4">

            <div class="card shadow-lg mb-4">
                <div class="card-body">
                    <h1 class="card-title">@CourseDetails.Name</h1>

                    <p class="text-muted">
                        <strong>Led by:</strong>
                        @foreach (var participant in CourseDetails.Participants.Where(p => p.Role == "Teacher"))
                        {
                            <span class="badge bg-primary me-1">@participant.FullName</span>
                        }
                    </p>

                    <p>@CourseDetails.Description</p>

                    <div class="mt-3">
                        <AuthorizeView Roles="Teacher">
                            <div class="alert alert-info">Teacher content</div>
                        </AuthorizeView>
                        <AuthorizeView Roles="Student">
                            <div class="alert alert-success">Student content</div>
                        </AuthorizeView>
                        <div class="alert alert-secondary">General content</div>
                    </div>
                </div>
            </div>

            <!-- Participants -->
            <div class="card shadow-sm mb-4">
                <div class="card-body">
                    <h3>Participants</h3>
                    <div class="d-flex flex-wrap gap-2 mt-2">
                        @foreach (var participant in CourseDetails.Participants.Where(p => p.Role != "Teacher"))
                        {
                            <span class="badge bg-light text-dark border">
                                @participant.FullName
                            </span>
                        }
                    </div>
                </div>
            </div>

            <!-- Modules -->
            <div>
                <h2 class="mb-3">Course Modules</h2>

                <div class="row">
                    @foreach (var module in CourseDetails.Modules)
                    {
                        <div class="col-md-6 col-lg-4">
                            <ModuleComponent Module="module"
                                             Activities="module.Activities" />
                        </div>
                    }
                </div>
            </div>

        </div>
    }

    if (Error != null)
    {
        <div>
            <h3>Something went wrong:</h3>
            <p>@Error</p>
        </div>
    }
}