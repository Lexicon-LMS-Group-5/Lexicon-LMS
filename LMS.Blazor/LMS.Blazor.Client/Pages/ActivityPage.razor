@page "/activity/{CourseId:int}/{ModuleId:int}/{ActivityId:int}"
@using LMS.Shared.DTOs
@inject IApiService ApiService
@inject NavigationManager NavigationManager

@if (Activity == null)
{
    <div class="d-flex justify-content-center mt-5">
        <div class="spinner-border text-primary"></div>
    </div>
}
else
{
    <Breadcrumbs CourseId="@CourseId"
                 ModuleId="@ModuleId"
                 CourseName="@Activity.CourseName"
                 ModuleName="@Activity.ModuleName"
                 ActivityName="@Activity.Name" />

    <div class="container py-4">

        <div class="mb-4">
            <button class="btn btn-outline-secondary btn-sm mb-3"
                    @onclick="DeleteThis">
                Delete this activity
            </button>

            <h1 class="fw-bold">@Activity.Name</h1>
            <p class="text-muted">@Activity.Description</p>
            <div class="mt-2">
                <span class="badge bg-primary fs-6 px-3 py-2">
                    @Activity.ActivityTypeName
                </span>
            </div>
        </div>

        <div class="card shadow-sm border-0 mb-4">
            <div class="card-body">
                <h5 class="card-title">Schedule</h5>

                <div class="row">
                    <div class="col-md-6">
                        <p class="mb-1">
                            <strong>Start Date</strong><br />
                            @Activity.StartDate.ToString("yyyy-MM-dd")
                        </p>
                    </div>

                    <div class="col-md-6">
                        <p class="mb-0">
                            <strong>End Date</strong><br />
                            @Activity.EndDate.ToString("yyyy-MM-dd")
                        </p>
                    </div>
                </div>
            </div>
        </div>

    </div>
}

@code {
    [Parameter] public int CourseId { get; set; }
    [Parameter] public int ModuleId { get; set; }
    [Parameter] public int ActivityId { get; set; }

    private ActivityReadDto? Activity;

    protected override async Task OnInitializedAsync()
    {
        Activity = await ApiService.GetAsync<ActivityReadDto>(
            $"api/activities/{ActivityId}");
    }

    private void GoBack()
    {
        NavigationManager.NavigateTo($"/module/{CourseId}/{ModuleId}");
    }
    private async Task DeleteThis()
    {
        await ApiService.DeleteAsync($"api/activities/{ActivityId}");
        GoBack();
    }
}
