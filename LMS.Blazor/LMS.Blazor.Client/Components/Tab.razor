
@if (CurrentTab == slug && ChildContent != null)
{
    @ChildContent
}

@code {
    [Parameter]
    public string Title { get; set; } = string.Empty;

    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    [SupplyParameterFromQuery(Name = "tab")]
    private string CurrentTab { get; set; } = string.Empty;

    private string slug { get => Title.ToLower().Replace(" ", "-"); }
}
