@using LMS.Shared
@using LMS.Shared.DTOs

<EditForm Model="Model" OnValidSubmit="HandleValidSubmit">
    <DataAnnotationsValidator />
    <ValidationSummary class="text-danger" />

    <div class="mb-3">
        <label class="form-label">First Name</label>
        <InputText class="form-control" @bind-Value="Model.FirstName" />
    </div>

    <div class="mb-3">
        <label class="form-label">Last Name</label>
        <InputText class="form-control" @bind-Value="Model.LastName" />
    </div>

    <div class="mb-3">
        <label class="form-label">Email</label>
        <InputText type="email" class="form-control" @bind-Value="Model.Email" />
    </div>

    @if (!string.IsNullOrEmpty(Error))
    {
        <div class="alert alert-danger">@Error</div>
    }

    <button type="button" class="btn btn-secondary"
            @onclick="@(() => { Error = string.Empty; OnCancel.InvokeAsync(); })">
        Cancel
    </button>

    <button type="submit" class="btn btn-primary me-2" disabled="@IsSubmitting">
        Create
    </button>
</EditForm>

@code {
    [Inject]
    private IApiService ApiService { get; set; } = default!;

    [Parameter]
    public EventCallback OnSaved { get; set; }

    [Parameter]
    public EventCallback OnCancel { get; set; }

    [Parameter]
    public int CourseId { get; set; }

    private UserCreateDto Model { get; set; } = new();
    private string? Error { get; set; }
    private bool IsSubmitting = false;

    private async Task HandleValidSubmit()
    {
        if (IsSubmitting) return;

        IsSubmitting = true;
        Error = string.Empty;

        try
        {
            Model.Roles = new List<string> { Roles.Student };
            Model.CourseId = CourseId;
            var result = await ApiService.PostAsync<UserCreateDto, UserReadDto>(
                "api/users", Model);

            if (result == null)
            {
                Error = "Creation failed";
                return;
            }

            await OnSaved.InvokeAsync();
        }
        catch (Exception ex)
        {
            Error = ex.Message;
        }
        finally
        {
            IsSubmitting = false;
        }
    }
}