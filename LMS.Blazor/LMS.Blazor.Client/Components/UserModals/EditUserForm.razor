@using LMS.Shared.DTOs
@if (Model == null || string.IsNullOrEmpty(Model.FirstName))
{
    <div class="text-center my-4">
        <div class="spinner-border" role="status"></div>
    </div>
}
else
{
    <EditForm Model="Model" OnValidSubmit="HandleValidSubmit">
        <DataAnnotationsValidator />
        <ValidationSummary class="text-danger" />

        <div class="mb-3">
            <label class="form-label">First Name</label>
            <InputText class="form-control" @bind-Value="Model.FirstName" />
        </div>

        <div class="mb-3">
            <label class="form-label">Last Name</label>
            <InputText class="form-control" @bind-Value="Model.LastName" />
        </div>

        <div class="mb-3">
            <label class="form-label">Email</label>
            <InputText type="email" class="form-control" @bind-Value="Model.Email" />
        </div>

        @if (!string.IsNullOrEmpty(Error))
        {
            <div class="alert alert-danger">@Error</div>
        }

        <button type="submit" class="btn btn-primary me-2" disabled="@IsSubmitting">Save</button>
        <button type="button" class="btn btn-secondary"
        @onclick="@(() => { Error = string.Empty; OnCancel.InvokeAsync(); })">
            Cancel
        </button>
    </EditForm>
}
@code {

    [Inject]
    private IApiService ApiService { get; set; } = default!;

    [Parameter]
    public string Id { get; set; } = string.Empty;

    [Parameter] 
    public EventCallback OnSaved { get; set; }

    [Parameter] 
    public EventCallback OnCancel { get; set; }

    private UserUpdateDto Model { get; set; } = new();
    private string? Error { get; set; }
    private bool IsSubmitting = false;

    protected override async Task OnParametersSetAsync()
    {
        if (string.IsNullOrEmpty(Id))
            throw new ArgumentException("Id is required for editing a user");

        try
        {
            var user = await ApiService.GetAsync<UserReadDto>($"api/users/{Id}");

            if (user == null)
            {
                Error = "User not found";
                return;
            }
            Model = new UserUpdateDto
            {
                FirstName = user.FirstName,
                LastName = user.LastName,
                Email = user.Email,
            };
        }
        catch (Exception ex)
        {
            Error = ex.Message;
        }
    }

    private async Task HandleValidSubmit()
    {
        if (IsSubmitting) return;
        IsSubmitting = true;
        Error = string.Empty;
        try
        {
            var result = await ApiService.PutAsync<UserUpdateDto, UserReadDto>(
                $"api/users/edit/{Id}", Model);

            if (result == null)
            {
                Error = "Update failed";
                return;
            }

            await OnSaved.InvokeAsync();
        }
        catch (Exception ex)
        {
            Error = ex.Message;
        }
        finally
        {
            IsSubmitting = false;
        }
    }
}
