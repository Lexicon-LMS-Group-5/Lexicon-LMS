@using LMS.Shared.DTOs
@inject IApiService ApiService

<div class="d-flex flex-column gap-2">

    <div class="mb-3">
        <label class="form-label">Activity Name</label>
        <input class="form-control" @bind="Name" />
    </div>

    <div class="mb-3">
        <label class="form-label">Description</label>
        <textarea class="form-control" rows="3" @bind="Description"></textarea>
    </div>

    <div class="mb-3">
        <label class="form-label">Start Date</label>
        <input type="date" class="form-control" @bind="StartDate" />
    </div>

    <div class="mb-3">
        <label class="form-label">End Date</label>
        <input type="date" class="form-control" @bind="EndDate" />
    </div>

    <div class="mb-3">
        <label class="form-label">Activity Type</label>
        <select class="form-select" @bind="SelectedActivityTypeId">
            @foreach (var type in ActivityTypes)
            {
                <option value="@type.Id">@type.Name</option>
            }
        </select>
    </div>

    <div class="mb-3">
        <div class="form-check">
            <input id="enableUpload" class="form-check-input" type="checkbox" @bind="EnableUpload" />
            <label class="form-check-label" for="enableUpload">
                Enable student upload
            </label>
        </div>

        @if (EnableUpload)
        {
            <div class="form-text mt-1">
                Students can upload files until the activity end date.
            </div>
        }
    </div>

    <div class="d-flex justify-content-end gap-2">
        <button class="btn btn-secondary" @onclick="HandleClose">
            @ModalCloseButton
        </button>

        <button class="btn btn-primary" @onclick="SaveActivity" disabled="@IsSaving">
            @if (IsSaving)
            {
                <span class="spinner-border spinner-border-sm"></span>
                <span class="ms-2">Saving...</span>
            }
            else
            {
                <span>Create Activity</span>
            }
        </button>
    </div>

    @if (!string.IsNullOrEmpty(Error))
    {
        <div class="text-danger">@Error</div>
    }
</div>

@code {
    [Parameter] public int CourseId { get; set; }
    [Parameter] public int ModuleId { get; set; }
    [Parameter] public EventCallback OnCreated { get; set; }
    [Parameter] public RenderFragment? ModalCloseButton { get; set; }

    private List<ActivityTypeReadDto> ActivityTypes { get; set; } = new();
    private int SelectedActivityTypeId { get; set; }

    private string Name { get; set; } = "";
    private string Description { get; set; } = "";

    private DateOnly StartDate { get; set; } = DateOnly.FromDateTime(DateTime.Today);
    private DateOnly EndDate { get; set; } = DateOnly.FromDateTime(DateTime.Today.AddDays(7));

    private bool EnableUpload { get; set; }

    private bool IsSaving;
    private string? Error;

    private async Task SaveActivity()
    {
        IsSaving = true;
        Error = null;

        try
        {
            var dto = new ActivityUpsertDto
            {
                Name = Name,
                Description = Description,
                StartDate = StartDate.ToDateTime(TimeOnly.MinValue),
                EndDate = EndDate.ToDateTime(TimeOnly.MinValue),
                ModuleId = ModuleId,
                ActivityTypeId = SelectedActivityTypeId,
                EnableUpload = EnableUpload
            };

            await ApiService.PostAsync<ActivityUpsertDto, ActivityReadDto>("api/activities", dto);
            ResetForm();
            await OnCreated.InvokeAsync();
        }
        catch (Exception ex)
        {
            Error = "Unexpected error: " + ex.Message;
        }
        finally
        {
            IsSaving = false;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        ActivityTypes = await ApiService.GetAsync<List<ActivityTypeReadDto>>("api/activitytypes");

        if (ActivityTypes != null && ActivityTypes.Any())
        {
            SelectedActivityTypeId = ActivityTypes.First().Id;
        }
    }

    private void ResetForm()
    {
        Name = "";
        Description = "";
        StartDate = DateOnly.FromDateTime(DateTime.Today);
        EndDate = DateOnly.FromDateTime(DateTime.Today.AddDays(7));
        EnableUpload = false;

        if (ActivityTypes.Any())
        {
            SelectedActivityTypeId = ActivityTypes.First().Id;
        }

        Error = null;
    }

    private void HandleClose()
    {
        ResetForm();
    }
}