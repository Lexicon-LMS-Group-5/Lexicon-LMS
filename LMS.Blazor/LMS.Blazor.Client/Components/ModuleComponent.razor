@using LMS.Shared.DTOs
@inject NavigationManager NavigationManager

<div class="card mb-4 shadow module-card" @onclick="NavigateToModule">
    <div class="card-body">
        <h4 class="card-title">@Module.Name</h4>
        <p class="card-text text-muted">@Module.Description</p>

        <small class="text-secondary">
            <i class="bi bi-calendar"></i>
            @Module.StartDate.ToShortDateString()
            -
            @Module.EndDate.ToShortDateString()
        </small>

        <hr />

        <div class="activities mt-3">
            @foreach (var activity in Activities)
            {
                <ActivityComponent Activity="activity" />
            }
        </div>
    </div>
</div>

@code {
    [Parameter, EditorRequired]
    public CourseModuleListItemDto Module { get; set; } = default!;

    [Parameter]
    public IEnumerable<ActivityReadDto> Activities { get; set; }

    private void NavigateToModule()
    {
        NavigationManager.NavigateTo($"/module/{Module.Id}");
    }
}